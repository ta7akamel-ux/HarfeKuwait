{
  "meta": {
    "project": "موقع حرفي الكويت للألومنيوم - MVP",
    "date": "2025-09-04",
    "prepared_by": "Manus AI"
  },
  "product_overview": "موقع ويب احترافي باللهجة الكويتية متخصص في صيانة وتصميم مطابخ الألومنيوم في الكويت، يقدم تجربة مستخدم متكاملة مع تحسين شامل لمحركات البحث وتصميم متجاوب مع دعم PWA.",
  "core_goals": [
    "تقديم معلومات واضحة وجذابة حول خدمات صيانة وتصميم مطابخ الألومنيوم بالكويت.",
    "توفير وسيلة اتصال متعددة القنوات للعملاء تشمل الهاتف، الواتساب، وسائل التواصل الاجتماعي، ونموذج الاتصال عبر الإنترنت.",
    "تحسين ظهور الموقع وأداءه في محركات البحث باستخدام SEO متقدم وتقنيات التحسين المختلفة.",
    "ضمان تجربة مستخدم سهلة وسلسة عبر تصفح متجاوب مع جميع الأجهزة وحماية الخصوصية.",
    "تقديم نظام تقييم ومراجعة من العملاء لدعم مصداقية الخدمة."
  ],
  "key_features": [
    "خلفية فيديو احترافية عالية الجودة مدمجة في الصفحة الرئيسية مع أوفرلي داكن لقراءة النصوص بوضوح.",
    "تصميم متجاوب يدعم اللغة العربية بالاتجاه من اليمين لليسار مع خطوط عربية احترافية (Tajawal & Cairo).",
    "نظام تنقل مرن ومتجاوب يشمل قائمة هامبرغر على الأجهزة المحمولة وتمرير سلس للأقسام المختلفة.",
    "نموذج اتصال متعدد الطرق مع تكامل مع EmailJS، Formspree وNetlify لتلبية متطلبات التواصل المتنوعة.",
    "نظام تقييم العملاء بنجمة مع جمع ملاحظات لتعزيز التفاعل والمصداقية.",
    "معرض صور يحمل الصور بشكل كسول مع وظيفة عرض الصور الضوء (lightbox) لعرض أمثلة أعمال الألومنيوم.",
    "تكامل Google Analytics لتتبع تفاعلات المستخدمين وأداء الموقع.",
    "توافق مع معايير تحسين محركات البحث (SEO) بما في ذلك Meta tags، Schema markup، Open Graph، ملف robots.txt وخريطة الموقع sitemap.xml.",
    "خاصية Progressive Web App (PWA) مع خدمة workers لدعم التصفح دون اتصال بالإنترنت.",
    "تكامل متعدد لطرق التواصل المباشر مثل الهاتف، واتساب، وسائل التواصل الاجتماعي، وتوليد ملف vCard للاتصال السريع."
  ],
  "user_flow_summary": [
    "الزائر يفتح الموقع ويرى خلفية فيديو جذابة مع العنوان الرئيسي والفرعي تأخذ اهتمامه فوراً.",
    "يعرض المستخدم التنقل السلس لاستكشاف الأقسام المختلفة كنبذة عن الشركة، الخدمات، ولماذا تختارنا، والمعرض، وقسم الاتصال.",
    "عبر نموذج الاتصال، يقوم المستخدم بإدخال بياناته مع اختياره نوع الخدمة والموافقة على سياسة الخصوصية ثم إرسال الرسالة من خلال إحدى طرق الإرسال المتعددة.",
    "يقوم المستخدم بتقييم الخدمة من خلال نظام التقييم بالنجوم مع ترك تعليقات لتحسين الخدمة وجودتها.",
    "يمكن للمستخدم الاطلاع على معرض الصور وتحميل الصور من خلال واجهة سهلة الاستخدام مع خاصية الضوء (lightbox).",
    "تتبع الموقع بفعالية عبر Google Analytics مما يمكن الفريق من تحسين التجربة باستمرار."
  ],
  "validation_criteria": [
    "التحقق من تحميل الموقع بنجاح على جميع المتصفحات المدعومة وأجهزة متعددة.",
    "اختبار نموذج الاتصال على جميع طرق الإرسال والتأكد من صحة التحقق من الحقول خاصة رقم الهاتف وفق القالب العربي ودقة البريد الإلكتروني.",
    "تأكيد عمل نظام تقييم العملاء وقبول قيم التقييم من 1 إلى 5 مع استقبال التعليقات بشكل صحيح.",
    "تأكد من تشغيل فيديو الخلفية أوتوماتيكياً بصمت على جميع الأجهزة ويعمل بشكل سلس.",
    "التحقق من أن جميع الصور في المعرض يتم تحميلها بكسل بشكل صحيح مع عمل خاصية lightbox بدون أخطاء.",
    "اختبار تجاوب واجهة الموقع مع جميع أحجام الشاشات من هواتف ذكية إلى شاشات مكتبية.",
    "تأكيد عمل خاصية التصفح دون إنترنت (offline) عبر خدمة PWA بدون فقدان الوظائف الأساسية.",
    "التأكد من دمج SEO عبر Meta tags وملفات sitemap.xml و robots.txt تعمل بشكل صحيح ويتم تحديثها.",
    "مراقبة وتتبع البيانات الصحيحة من Google Analytics لضمان رصد تفاعلات المستخدم بدقة."
  ],
