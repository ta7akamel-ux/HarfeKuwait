{
  "tech_stack": [
    "HTML5",
    "CSS3",
    "JavaScript (ES6+)",
    "PWA (Progressive Web App)",
    "Service Worker",
    "EmailJS",
    "Google Analytics",
    "AOS (Animate On Scroll)",
    "Font Awesome",
    "Google Fonts",
    "Netlify Forms",
    "Formspree"
  ],
  "features": [
    {
      "name": "Landing Page",
      "description": "Main Arabic landing page with hero section, navigation, and company branding",
      "files": ["index.html", "css/style.css"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Landing Page",
          "version": "1.0.0",
          "description": "Static landing page with responsive design"
        },
        "paths": {
          "/": {
            "get": {
              "summary": "Load main landing page",
              "responses": {
                "200": {
                  "description": "HTML page served successfully"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Contact Form",
      "description": "Multi-method contact form with EmailJS, Formspree, and Netlify Forms integration",
      "files": ["index.html", "js/script.js", "emailjs-config.js"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Contact Form API",
          "version": "1.0.0",
          "description": "Contact form with multiple submission methods"
        },
        "paths": {
          "/contact": {
            "post": {
              "summary": "Submit contact form",
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "name": {"type": "string", "description": "Customer name in Arabic"},
                        "phone": {"type": "string", "pattern": "^(\\+965|965|00965)?[2456789]\\d{7}$"},
                        "email": {"type": "string", "format": "email"},
                        "service": {"type": "string", "description": "Type of service requested"},
                        "message": {"type": "string", "minLength": 10, "maxLength": 1000},
                        "privacy": {"type": "boolean", "description": "Privacy policy agreement"}
                      },
                      "required": ["name", "phone", "email", "message", "privacy"]
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Form submitted successfully"
                },
                "400": {
                  "description": "Validation error"
                },
                "500": {
                  "description": "Submission failed"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Rating System",
      "description": "Customer rating and review system with star ratings and feedback",
      "files": ["index.html", "js/script.js"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Rating System API",
          "version": "1.0.0",
          "description": "Customer rating and feedback system"
        },
        "paths": {
          "/rating": {
            "post": {
              "summary": "Submit customer rating",
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "customerName": {"type": "string", "description": "Customer name"},
                        "rating": {"type": "integer", "minimum": 1, "maximum": 5},
                        "feedback": {"type": "string", "description": "Customer feedback"}
                      },
                      "required": ["customerName", "rating", "feedback"]
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Rating submitted successfully"
                },
                "400": {
                  "description": "Invalid rating data"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Image Gallery",
      "description": "Lazy-loaded image gallery with lightbox functionality showcasing aluminum kitchen work",
      "files": ["index.html", "css/style.css", "js/script.js", "assets/gallery/"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Image Gallery API",
          "version": "1.0.0",
          "description": "Gallery with lazy loading and lightbox"
        },
        "paths": {
          "/gallery": {
            "get": {
              "summary": "Load gallery images",
              "responses": {
                "200": {
                  "description": "Gallery images loaded successfully"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Navigation System",
      "description": "Responsive navigation with smooth scrolling and mobile hamburger menu",
      "files": ["index.html", "css/style.css", "js/script.js"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Navigation System",
          "version": "1.0.0",
          "description": "Responsive navigation with smooth scrolling"
        },
        "paths": {
          "/#section": {
            "get": {
              "summary": "Navigate to page section",
              "parameters": [
                {
                  "name": "section",
                  "in": "path",
                  "required": true,
                  "schema": {
                    "type": "string",
                    "enum": ["home", "about", "services", "why-us", "gallery", "contact"]
                  }
                }
              ],
              "responses": {
                "200": {
                  "description": "Section displayed successfully"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "PWA Features",
      "description": "Progressive Web App functionality with service worker, caching, and offline support",
      "files": ["sw.js", "manifest.json"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "PWA Service Worker API",
          "version": "1.0.0",
          "description": "Progressive Web App with offline capabilities"
        },
        "paths": {
          "/sw.js": {
            "get": {
              "summary": "Load service worker",
              "responses": {
                "200": {
                  "description": "Service worker loaded successfully"
                }
              }
            }
          },
          "/manifest.json": {
            "get": {
              "summary": "Load PWA manifest",
              "responses": {
                "200": {
                  "description": "Manifest loaded successfully"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Contact Methods",
      "description": "Multiple contact methods including phone, WhatsApp, social media, and vCard generation",
      "files": ["index.html", "js/script.js"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Contact Methods API",
          "version": "1.0.0",
          "description": "Various contact integration methods"
        },
        "paths": {
          "/contact/phone": {
            "get": {
              "summary": "Initiate phone call",
              "responses": {
                "200": {
                  "description": "Phone call initiated"
                }
              }
            }
          },
          "/contact/whatsapp": {
            "get": {
              "summary": "Open WhatsApp chat",
              "responses": {
                "200": {
                  "description": "WhatsApp opened successfully"
                }
              }
            }
          },
          "/contact/vcard": {
            "get": {
              "summary": "Generate vCard contact file",
              "responses": {
                "200": {
                  "description": "vCard generated successfully",
                  "content": {
                    "text/vcard": {
                      "schema": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Analytics Integration",
      "description": "Google Analytics integration for tracking user interactions and form submissions",
      "files": ["index.html", "js/script.js"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Analytics API",
          "version": "1.0.0",
          "description": "Google Analytics tracking integration"
        },
        "paths": {
          "/analytics/track": {
            "post": {
              "summary": "Track user event",
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "event_category": {"type": "string"},
                        "event_action": {"type": "string"},
                        "event_label": {"type": "string"},
                        "value": {"type": "number"}
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Event tracked successfully"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "SEO Optimization",
      "description": "Search engine optimization with meta tags, structured data, and sitemap",
      "files": ["index.html", "sitemap.xml", "robots.txt"],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "SEO Components",
          "version": "1.0.0",
          "description": "SEO optimization features"
        },
        "paths": {
          "/sitemap.xml": {
            "get": {
              "summary": "Get XML sitemap",
              "responses": {
                "200": {
                  "description": "Sitemap XML returned",
                  "content": {
                    "application/xml": {
                      "schema": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "/robots.txt": {
            "get": {
              "summary": "Get robots.txt file",
              "responses": {
                "200": {
                  "description": "Robots.txt returned"
                }
              }
            }
          }
        }
      }
    }
  ]
}
